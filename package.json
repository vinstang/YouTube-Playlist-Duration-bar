{
    "name": "youtube-playlist-duration-bar",
    "version": "0.6.5",
    "description": "A Chrome/Firefox extension to display a progress bar showing playlist progress and duration.",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "build:chrome": "cross-env TARGET=chrome vite build",
        "build:firefox": "cross-env TARGET=firefox vite build",
        "lint": "eslint src scripts --no-error-on-unmatched-pattern",
        "lint:fix": "eslint src scripts --fix --no-error-on-unmatched-pattern",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "type-check": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@playwright/test": "^1.58.2",
        "@types/chrome": "^0.0.320",
        "@vitest/coverage-v8": "^3.0.0",
        "cross-env": "^7.0.3",
        "eslint": "^9.19.0",
        "globals": "^17.4.0",
        "playwright": "^1.58.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.23.0",
        "vite": "^6.1.0",
        "vite-plugin-static-copy": "^3.2.0",
        "vite-plugin-web-extension": "^4.2.0",
        "vitest": "^3.0.5"
    }
}
